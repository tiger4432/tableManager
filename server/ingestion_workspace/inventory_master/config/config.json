{
  "table_name": "inventory_master",
  "source_name": "advanced_ingester",
  "updated_by": "agent_q_v2",
  "business_key_column": "part_no",
  "header_rules": [
    {
      "column": "dept_code",
      "regex": "DEPT: (\\w+)",
      "type": "str"
    },
    {
      "column": "batch_id",
      "regex": "BATCH_ID: ([A-Z0-9-]+)",
      "type": "str"
    }
  ],
  "rules": [
    {
      "column": "part_no",
      "regex": "PartNo: ([A-Z0-9-]+)",
      "type": "str",
      "required": true
    },
    {
      "column": "stock_qty",
      "regex": "Qty: (\\d+)",
      "type": "int",
      "default": 0
    },
    {
      "column": "category",
      "regex": "Type: (\\w+)",
      "type": "str",
      "default": "Unknown"
    },
    {
      "column": "unit_price",
      "regex": "Price: (\\d+\\.?\\d*)",
      "type": "float"
    }
  ]
}
