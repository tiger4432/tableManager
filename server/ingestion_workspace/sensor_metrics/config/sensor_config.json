{
  "table_name": "sensor_metrics",
  "source_name": "sensor_edge_parser",
  "updated_by": "agent_i_v3",
  "business_key_column": "sensor_id",
  "header_rules": [
    {
      "column": "site_name",
      "regex": "Site: ([A-Za-z0-9 ]+)",
      "type": "str"
    },
    {
      "column": "sensor_group",
      "regex": "Group: ([A-Z0-9-]+)",
      "type": "str"
    }
  ],
  "table_start_pattern": "--- START METRICS ---",
  "table_end_pattern": "--- END METRICS ---",
  "rules": [
    {
      "column": "sensor_id",
      "regex": "ID: (SENSOR-\\d+)",
      "type": "str",
      "required": true
    },
    {
      "column": "temperature",
      "regex": "Temp: (\\d+\\.?\\d*)",
      "type": "float"
    },
    {
      "column": "humidity",
      "regex": "Humi: (\\d+\\.?\\d*)",
      "type": "float"
    },
    {
      "column": "vibration",
      "regex": "Vibr: (\\d+\\.?\\d*)",
      "type": "float"
    }
  ]
}
